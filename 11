# Projection lines 
For i in range(len(X)): 
Plt.plot([X[i,0], X_part[i,0]], [X[i,1], X_part[i,1]]) 
Plt.title(“PCA Reconstruction”) 
Plt.xlabel(“x1”) 
Plt.ylabel(“x2”) 
Plt.legend() 
Plt.grid() 
Plt.axis(‘equal’) 
Plt.show()
